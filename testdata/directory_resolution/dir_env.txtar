# TICKETS_DIR env var selects the right project
exec ko add 'Default ticket'
exec ko ls
stdout 'Default ticket'

# Create a second project in a different dir
mkdir $WORK/other/.ko/tickets
env TICKETS_DIR=$WORK/other/.ko/tickets
exec ko add 'Other ticket'
exec ko ls
stdout 'Other ticket'
! stdout 'Default ticket'

-- .ko/tickets/.keep --
