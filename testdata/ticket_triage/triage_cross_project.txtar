# ko triage sets triage on a cross-project ticket by ID prefix
env HOME=$WORK/home
mkdir $WORK/home

# Register the "fn" project and create a ticket via ko add
mkdir $WORK/fn/.ko
mkdir $WORK/fn/.ko/tickets
cd $WORK/fn
exec ko project set '#fn'
exec ko add 'Cross-project ticket'

# Change to a directory outside the fn project
cd $WORK/outside

# Triage the ticket using partial prefix lookup (fn- resolves across projects)
exec ko triage fn- do something
stdout 'updated'

# Verify triage was applied
exec ko show --project fn fn-
stdout 'triage: do something'

-- outside/.gitkeep --
